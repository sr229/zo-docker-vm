{
    "_comment": "Example docker-vm config. Normally this file lives under $XDG_STATE_HOME/docker-vm/config.json (or ~/.local/state/docker-vm/config.json). You should not need to edit it by hand; the CLI manages it.",

    "image_path": "~/.local/state/docker-vm/image.qcow2",
    "image_url": "https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-generic-arm64.qcow2",
    "disk_size": "50G",
    "log_file": "~/.local/state/docker-vm/docker-vm.log",
    "port_forwards": {
        "2222": "22"
    },
    "workspace": "/home/workspace"
}
